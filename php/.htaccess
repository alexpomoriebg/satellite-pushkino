# PHP CMS for Astro satellite site
DirectoryIndex index.php

# Enable rewrite engine
RewriteEngine On

# Force HTTPS (Timeweb uses reverse proxy)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Dynamic sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Block access to private directories
RewriteRule ^_data/ - [F,L]
# Allow API endpoint, block everything else in _inc/
RewriteRule ^_inc/api-save\.php$ - [L]
RewriteRule ^_inc/ - [F,L]

# ===== 301 REDIRECTS: old WordPress URLs → new pages =====

# --- Category pages ---
RewriteRule ^steklo\.html$ /steklo/ [L,R=301]
RewriteRule ^prozrachnoe-steklo\.html$ /steklo/ [L,R=301]
RewriteRule ^uzorchatoe-steklo\.html$ /steklo/ [L,R=301]
RewriteRule ^satinato\.html$ /steklo/ [L,R=301]
RewriteRule ^okonnoe-steklo\.html$ /steklo/ [L,R=301]
RewriteRule ^obzor-steklo\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-optom\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-10-mm\.html$ /steklo/ [L,R=301]
RewriteRule ^krizet\.html$ /steklo/ [L,R=301]

# --- Steklopakety ---
RewriteRule ^steklopakety-ot-1-shtuki\.html$ /steklopakety/ [L,R=301]
RewriteRule ^odnokamernye-steklopakety\.html$ /steklopakety/ [L,R=301]
# Allow article subdirectories, redirect old WP subpages
RewriteRule ^steklopakety/kak-vybrat/ - [L]
RewriteRule ^steklopakety/zamena-steklopaketa/ - [L]
RewriteRule ^steklopakety/(.+)$ /steklopakety/ [L,R=301]

# --- Shower glass ---
RewriteRule ^dushevye/steklo-dlya-dushevoj/ - [L]
RewriteRule ^dushevye/dushevaya-iz-stekla-svoimi-rukami/ - [L]

# --- Teplicy redirect (no greenhouse section on this satellite) ---
RewriteRule ^teplicy(/.*)?$ / [L,R=301]

# --- Services ---
RewriteRule ^zakalennoe-steklo\.html$ /uslugi/ [L,R=301]
RewriteRule ^rezka\.html$ /uslugi/ [L,R=301]
RewriteRule ^figurnaya-rezka-stekla\.html$ /uslugi/ [L,R=301]
RewriteRule ^rezka-stekla-dlya-akvariuma\.html$ /uslugi/ [L,R=301]
RewriteRule ^stoleshnicy\.html$ /produkciya/ [L,R=301]
RewriteRule ^skinali\.html$ /produkciya/ [L,R=301]

# --- Other pages ---
RewriteRule ^koordinati\.html$ /kontakty/ [L,R=301]
RewriteRule ^raschyot\.html$ /online-raschet/ [L,R=301]
RewriteRule ^oplata\.html$ /dostavka/ [L,R=301]
RewriteRule ^dostavka\.html$ /dostavka/ [L,R=301]
RewriteRule ^akcii\.html$ / [L,R=301]
RewriteRule ^cart\.html$ / [L,R=301]
RewriteRule ^politika-konfidencialnosti\.html$ / [L,R=301]

# --- Bulk product pages → category pages ---
RewriteRule ^steklo-prozrachnoe-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-bronza-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-matovoe-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-seroe-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-osvetlennoe-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-armirovannoe-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^steklo-(.+)\.html$ /steklo/ [L,R=301]
RewriteRule ^prozrachnoe-steklo-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^tonirovannoe-steklo-(.*)\.html$ /steklo/ [L,R=301]
RewriteRule ^uzorchatoe-steklo-(.*)\.html$ /steklo/ [L,R=301]

# --- Mirrors ---
RewriteRule ^zerkalo-(.*)\.html$ /zerkala/ [L,R=301]

# --- Triplex ---
RewriteRule ^tripleks-(.*)\.html$ /produkciya/ [L,R=301]

# --- WordPress taxonomy URLs ---
RewriteRule ^steklo/tonirovannoe-steklo(/.*)?$ /steklo/ [L,R=301]
RewriteRule ^steklo/matovoe-steklo(/.*)?$ /steklo/ [L,R=301]
RewriteRule ^steklo/tripleks(/.*)?$ /produkciya/ [L,R=301]
RewriteRule ^steklo/page/(.+)$ /steklo/ [L,R=301]
RewriteRule ^steklo\.html\?vpage=(.*)$ /steklo/ [L,R=301,QSD]

# --- WordPress system URLs ---
RewriteRule ^wp-json/(.*)$ / [L,R=301]
RewriteRule ^wp-content/(.*)$ / [L,R=301]
RewriteRule ^wp-includes/(.*)$ / [L,R=301]

# --- Blog articles ---
RewriteRule ^laxta-centr-(.*)\.html$ / [L,R=301]
RewriteRule ^issledovateli-(.*)\.html$ / [L,R=301]
RewriteRule ^karol-miln-(.*)\.html$ / [L,R=301]

# --- Catch-all .html ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)\.html$ / [L,R=301]

# ===== END REDIRECTS =====

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
