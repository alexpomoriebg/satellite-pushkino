# PHP CMS for Astro satellite site
DirectoryIndex index.php

# Enable rewrite engine
RewriteEngine On

# Force HTTPS (Timeweb uses reverse proxy)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Dynamic sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Block access to private directories
RewriteRule ^_data/ - [F,L]
# Allow API endpoint, block everything else in _inc/
RewriteRule ^_inc/api-save\.php$ - [L]
RewriteRule ^_inc/ - [F,L]
# ===== 301 REDIRECTS: old WordPress URLs → new pages =====
# Generated by scripts/build-htaccess-redirects.py (v2 after SEO audit) on 2026-04-24
# Covers all 2042 old WP URLs:
#   ~1800 → specific category (steklo/steklopakety/uslugi/produkciya/zerkala/dostavka)
#   ~120 → 410 Gone (obsolete articles without equivalents)
#   ~120 → / (only system pages: cart, akcii, politika)

# Note: 301-rules use "/target/?" (trailing "?" in target).
# Empty query string after "?" tells Apache to DROP client's ?utm=/?fbclid=/?vpage=
# in a SINGLE 301 hop (no 2-step chains). Works on all Apache 2.x versions.

# --- Direct 1:1 for article slugs that exist as live pages ---
# Live pages are NESTED under /steklo/ or /steklopakety/, not root.
# This preserves link juice from old .html URLs to matching articles.
RewriteRule ^vidy-stekla[-a-z0-9]*\.html$ /steklo/vidy-stekla/? [L,R=301]
RewriteRule ^zvukoizolyaciya[-a-z0-9]*\.html$ /zvukoizolyaciya/? [L,R=301]
RewriteRule ^kak-vybrat-steklopaket[-a-z0-9]*\.html$ /steklopakety/kak-vybrat/? [L,R=301]
RewriteRule ^zamena-steklopaketa[-a-z0-9]*\.html$ /steklopakety/zamena-steklopaketa/? [L,R=301]
RewriteRule ^zakalennoe-vs-obychnoe[-a-z0-9]*\.html$ /steklo/zakalennoe-vs-obychnoe/? [L,R=301]
# Safeguard: if old slug was "zakalennoe-steklo-vs-obychnoe"
RewriteRule ^zakalennoe-steklo-vs-obychnoe[-a-z0-9]*\.html$ /steklo/zakalennoe-vs-obychnoe/? [L,R=301]

# --- System pages → / (главная) ---
RewriteRule ^(akcii|cart|politika-konfidencialnosti|login|registration|profile|my-account|praise|skidki|skidka-5|zayavka-otpravlena|sotrydnichestvo|rabota-s-eetp|postavshhik-stekla|vesennyaya_pesnya|t1)\.html$ / [L,R=301]

# --- Contacts / delivery / calculator ---
RewriteRule ^koordinati\.html$ /kontakty/? [L,R=301]
RewriteRule ^oplata\.html$ /dostavka/? [L,R=301]
RewriteRule ^dostavka\.html$ /dostavka/? [L,R=301]
RewriteRule ^dostavkama?[0-9]+\.html$ /dostavka/? [L,R=301]
RewriteRule ^dostavkam?\.html$ /dostavka/? [L,R=301]
RewriteRule ^raschyot\.html$ /online-raschet/? [L,R=301]
RewriteRule ^raschet\.html$ /online-raschet/? [L,R=301]

# --- Steklopakety (insulated glass units) ONLY ---
# Note: "okna" goes here because it's pl. plastic windows (uses IGU).
# "okonnoe-steklo" is MATERIAL → /steklo/ (see below). Do not merge these two.
RewriteRule ^okna[-a-z0-9]*\.html$ /steklopakety/? [L,R=301]
RewriteRule ^steklopak[a-z0-9-]*\.html$ /steklopakety/? [L,R=301]
RewriteRule ^(odno|dvux|trex)kamern[a-z0-9-]*steklopaket[a-z0-9-]*\.html$ /steklopakety/? [L,R=301]
RewriteRule ^(odno|dvux|trex)kamernyj-steklopaket[a-z0-9-]*\.html$ /steklopakety/? [L,R=301]
# Keep existing article subdirs functional
RewriteRule ^steklopakety/kak-vybrat/ - [L]
RewriteRule ^steklopakety/zamena-steklopaketa/ - [L]
RewriteRule ^steklopakety/(.+)$ /steklopakety/? [L,R=301]

# --- Mirrors (zerkala) ---
RewriteRule ^zerkal[a-z0-9-]*\.html$ /zerkala/? [L,R=301]

# --- Services (uslugi) ---
RewriteRule ^(rezka|figurnaya-rezka-stekla|figurnaya|hudozhestvennaya-rezka-stekla|polirovka|obrabotka-kromki-stekla|obrabotka)[-a-z0-9]*\.html$ /uslugi/? [L,R=301]
RewriteRule ^zakalennoe-steklo[-a-z0-9]*\.html$ /uslugi/? [L,R=301]
RewriteRule ^zakalka-stekla[-a-z0-9]*\.html$ /uslugi/? [L,R=301]
RewriteRule ^ultrafioletovaya-sklejka-stekla[-a-z0-9]*\.html$ /uslugi/? [L,R=301]
RewriteRule ^rezka-stekla[-a-z0-9]*\.html$ /uslugi/? [L,R=301]

# --- Doors / interior glass products → /produkciya/ ---
RewriteRule ^dveri[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^mezhkomnatnye-dveri[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^mebel[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^izdeli[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^fartuk[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^kuxonnyj-fartuk[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^skinali[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^stoleshnic[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^polk[ai][-a-z0-9]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^(peregorodk|partition)[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^(balkon|osteklenie|veranda)[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^dushev[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^(sauna|banya)[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^teplic[a-z0-9-]*\.html$ /produkciya/? [L,R=301]
RewriteRule ^stekla-dlya-xolodilnoj-vitriny\.html$ /produkciya/? [L,R=301]
RewriteRule ^poly[-a-z0-9]*\.html$ /produkciya/? [L,R=301]
# Tripleks = laminated glass product (доп. обработка), preserved /produkciya/ mapping from old .htaccess
RewriteRule ^tripleks[-a-z0-9]*\.html$ /produkciya/? [L,R=301]

# --- Glass types (материал) → /steklo/ ---
RewriteRule ^(armirovannoe|osvetlennoe|listovoe|polirovannoe|matovoe|tonirovann|uzorchat|krizet|satinato)[-a-z0-9]*\.html$ /steklo/? [L,R=301]
RewriteRule ^(prozrachnoe|bronza|seroe|zelenoe)-steklo[-a-z0-9]*\.html$ /steklo/? [L,R=301]
RewriteRule ^okonnoe-steklo[-a-z0-9]*\.html$ /steklo/? [L,R=301]
RewriteRule ^(steklo-optom|obzor-steklo|steklo-10-mm)[-a-z0-9]*\.html$ /steklo/? [L,R=301]
RewriteRule ^steklo[-a-z0-9]*\.html$ /steklo/? [L,R=301]
RewriteRule ^rasprodazha-armirovannogo-stekla\.html$ /steklo/? [L,R=301]
# Catch "anything-steklo-anything.html" that hasn't matched yet
RewriteRule ^[a-z0-9-]*-steklo[-a-z0-9]*\.html$ /steklo/? [L,R=301]
RewriteRule ^[a-z0-9-]*-stekla[-a-z0-9]*\.html$ /steklo/? [L,R=301]

# --- WordPress system URLs ---
RewriteRule ^wp-json/(.*)$ / [L,R=301]
RewriteRule ^wp-content/(.*)$ / [L,R=301]
RewriteRule ^wp-includes/(.*)$ / [L,R=301]
RewriteRule ^wp-admin/?(.*)$ / [L,R=301]

# --- WordPress taxonomy URLs ---
# Keep real live subpages accessible
RewriteRule ^steklo/vidy-stekla/ - [L]
RewriteRule ^steklo/zakalennoe-vs-obychnoe/ - [L]
RewriteRule ^steklo/tonirovannoe-steklo(/.*)?$ /steklo/? [L,R=301]
RewriteRule ^steklo/matovoe-steklo(/.*)?$ /steklo/? [L,R=301]
RewriteRule ^steklo/tripleks(/.*)?$ /produkciya/? [L,R=301]
RewriteRule ^steklo/(.+)$ /steklo/? [L,R=301]

# --- Unrelated old articles/news → 410 Gone ---
# These are WordPress blog posts that have no equivalent on the new site.
# 410 tells search engines the page is permanently removed (better than soft-404).
# TODO: before next cleanup, export top-20 old articles by backlinks from Yandex.Webmaster
# and give them individual 301s to preserve link juice.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)\.html$ - [G,L]

# ===== END REDIRECTS =====

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
